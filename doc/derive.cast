[5.106, "o", "\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m\u001b[1;1H x  #\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[1;17Hdouble#\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u001b[2;19H\u2588    \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[48;5;234m\u001b[3;1H   1 \u001b(B\u001b[m\u001b[38;5;16;48;5;15m\u001b[3;19H   2 \u001b(B\u001b[m\u2502\u001b[4;1H   2 \u001b(B\u001b[m\u001b[48;5;238m\u001b[4;19H   4 \u001b(B\u001b[m\u2502\u001b[5;1H   3 \u001b(B\u001b[m\u001b[48;5;238m\u001b[5;19H   6 \u001b(B\u001b[m\u2502\u001b[6;1H   4 \u001b(B\u001b[m\u001b[48;5;238m\u001b[6;19H   8 \u001b(B\u001b[m\u2502\u001b[7;1H   5 \u001b(B\u001b[m\u001b[48;5;238m\u001b[7;19H  10 \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m\u001b[22;1H x  #\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[22;19H dou#\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;7;48;5;4m\u001b[23;1Hnumeric.csv \u2502\u001b[23;15H[=double]\u001b(B\u001b[m\u001b[38;5;8;48;5;4m\u001b[23;55Hderive {`double` = x * 2}\u001b(B\u001b[m\u001b[38;5;6m\u001b[24;1Hdouble\u001b(B\u001b[m\u001b[38;5;8m\u001b[24;28H30\u001b[24;36H6\u001b(B\u001b[m\u001b[38;5;6m\u001b[24;61H3\u001b[24;63H4"]
