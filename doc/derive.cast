[1.11, "o", "\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[1;1H x  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m y  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m z  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u001b[2;1H\u2588    \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u2588    \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u2588    \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;16;48;5;15m\u001b[3;1H   1 \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[48;5;234m  10 \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[48;5;234m 100 \u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[4;1H   2 \u001b(B\u001b[m\u2502\u001b[4;9H20\u001b[4;12H\u2502\u001b[4;14H200\u001b[4;18H\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[5;1H   3 \u001b(B\u001b[m\u2502\u001b[5;9H30\u001b[5;12H\u2502\u001b[5;14H300\u001b[5;18H\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[6;1H   4 \u001b(B\u001b[m\u2502\u001b[6;9H40\u001b[6;12H\u2502\u001b[6;14H400\u001b[6;18H\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[7;1H   5 \u001b(B\u001b[m\u2502\u001b[7;9H50\u001b[7;12H\u2502\u001b[7;14H500\u001b[7;18H\u2502\u001b(B\u001b[m\u001b[38;5;16;48;5;3m\u001b[17;59H    T toggle row sel\u001b[18;59H    ! group by      \u001b[19;59H   c\\ hide column   \u001b[20;59H S-\u2190\u2192 reorder cols  \u001b[21;59H  SPC command menu  \u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[22;1H x  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m y  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m z  #\u001b(B\u001b[m\u2502\u001b(B\u001b[m\u001b[38;5;7;48;5;4m\u001b[23;1H[numeric.csv]                                                                   \u001b(B\u001b[m\u001b[38;5;6m\u001b[24;1Hx                         \u001b(B\u001b[m\u001b[38;5;8m\u03a315.000 \u03bc3.000 #5\u001b(B\u001b[m\u001b[38;5;6m                c0/3 grp=0 sel=0 r0/5"